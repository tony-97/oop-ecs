{
  "makefile.makefilePath": "vscode.mk",
  "makefile.configurations": [
    {
      "name": "Debug",
      "makeArgs": ["BUILD_MODE=DEBUG"]
    },
    {
      "name": "Release",
      "makeArgs": ["BUILD_MODE=RELEASE"]
    }
  ],
  "makefile.compileCommandsPath": "./compile_commands.json",
  "makefile.launchConfigurations": [
    {
      "cwd": "${workspaceFolder}/build/debug",
      "binaryPath": "${workspaceFolder}/build/debug/ecs.exe",
      "binaryArgs": []
    },
    {
      "cwd": "${workspaceFolder}/build/release",
      "binaryPath": "${workspaceFolder}/build/release/ecs.exe",
      "binaryArgs": []
    }
  ]
}
